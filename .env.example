# Entra External ID – app registration
# e.g. https://<tenant>.ciamlogin.com/<tenant>.onmicrosoft.com
VITE_ENTRA_AUTHORITY=

# Azure app registration client ID (found in Azure Portal → App registrations)
VITE_ENTRA_CLIENT_ID=

# Redirect URI after login – must be registered in Azure Portal
# For local dev: http://localhost:5173
# For production: https://<frontend>.azurewebsites.net
VITE_ENTRA_REDIRECT_URI=http://localhost:5173

# API scope to request in the access token
# e.g. api://<api-client-id>/user_impersonation
VITE_ENTRA_API_SCOPE=

# Backend API base URL (no trailing slash)
# For local dev: http://localhost:3001/api/v1
# For production: https://<api-app>.azurewebsites.net/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1
