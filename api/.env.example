# Entra External ID JWKS endpoint
# e.g. https://<tenant>.ciamlogin.com/<tenant>.onmicrosoft.com/discovery/v2.0/keys
ENTRA_JWKS_URI=

# Token issuer (must match the iss claim in access tokens)
# e.g. https://<tenant>.ciamlogin.com/<tenant>.onmicrosoft.com/v2.0
ENTRA_ISSUER=

# Azure app registration client ID (used as token audience)
ENTRA_CLIENT_ID=

# Azure Cosmos DB
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DB_NAME=eng2br
COSMOS_CONTAINER_NAME=user_progress

# CORS – allowed origin for the frontend (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# Server port (default: 3001)
PORT=3001
